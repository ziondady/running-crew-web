{
	"appId": "fit.run4u.app",
	"appName": "배틀크루",
	"webDir": "out",
	"server": {
		"url": "https://run4u.fit",
		"cleartext": false,
		"androidScheme": "https"
	},
	"android": {
		"allowMixedContent": true
	},
	"plugins": {
		"PushNotifications": {
			"presentationOptions": [
				"badge",
				"sound",
				"alert"
			]
		},
		"BackgroundGeolocation": {}
	},
	"packageClassList": [
		"BackgroundGeolocation",
		"FilesystemPlugin",
		"GeolocationPlugin",
		"PushNotificationsPlugin"
	]
}
